{
  "name": "speedo",
  "version": "0.0.1",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    {
      "name": "vcpkg-cmake-get-vars",
      "host": true
    },
    {
      "name": "vcpkg-tool-fastbuild",
      "host": true
    },
    {
      "name": "llvm",
      "default-features": false,
      "features": [
        "clang",
        "clang-tools-extra",
        "default-targets",
        "libcxx",
        "lld"
      ],
      "host": true
    },
    {
      "name": "llvm",
      "default-features": false,
      "features": [ "libcxxabi" ],
      "platform": "!windows",
      "host": true
    }
  ],
  "features": {
    "common": {
      "description": "Common Dependencies for both Client and Server",
      "dependencies": [
        "cargs",
        "concurrentqueue",
        "cppzmq",
        "cpptrace",
        {
          "name": "mimalloc",
          "features": [
            "override",
            "secure"
          ]
        },
        "mio",
        "picosha2",
        "sha-intrinsics",
        "stduuid",
        "tl-function-ref",
        "tracy",
        "unordered-dense",
        "xxhash",
        "zpp-bits"
      ]
    },
    "client": {
      "description": "Game Client Executable",
      "dependencies": [
        {
          "name": "speedo",
          "default-features": false,
          "features": [ "common" ]
        },
        "cgltf",
        "glfw3",
        {
          "name": "glfw3",
          "default-features": false,
          "features": [ "wayland" ],
          "platform": "linux"
        },
        "glm",
        {
          "name": "imgui",
          "features": [
            "glfw-binding",
            "vulkan-binding"
          ]
        },
        "nativefiledialog-extended",
        "shader-slang",
        "stb",
        "tinyobjloader",
        {
          "name": "tracy",
          "features": [ "gui-tools" ]
        },
        "vulkan",
        "vulkan-headers",
        "vulkan-loader",
        "vulkan-memory-allocator",
        "vulkan-utility-libraries",
        "vulkan-validationlayers"
      ]
    },
    "server": {
      "description": "Game Server Executable",
      "dependencies": [
        {
          "name": "speedo",
          "default-features": false,
          "features": [ "common" ]
        }
      ]
    }
  },
  "default-features": [
    "client",
    "server"
  ],
  "builtin-baseline": "62159a45e18f3a9ac0548628dcaf74fcb60c6ff9"
}
